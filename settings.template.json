{
  "_comment_env": "Environment variables injected into every Claude Code session. Leave a value blank or remove the key entirely to use defaults. See docs/CUSTOMIZATION.md.",
  "env": {
    "CLAUDE_CODE_EXPERIMENTAL_AGENT_TEAMS": "1",

    "_comment_gateway": "Leave ANTHROPIC_BASE_URL empty to hit the official api.anthropic.com. Fill only if you route through a custom gateway.",
    "ANTHROPIC_BASE_URL": "",

    "ANTHROPIC_DEFAULT_OPUS_MODEL": "claude-opus-4-6",
    "ANTHROPIC_DEFAULT_SONNET_MODEL": "claude-sonnet-4-6",
    "ANTHROPIC_DEFAULT_HAIKU_MODEL": "claude-haiku-4-5",

    "CLAUDE_CODE_DISABLE_EXPERIMENTAL_BETAS": "1",
    "CLAUDE_CODE_USE_BEDROCK": "0",
    "DISABLE_PROMPT_CACHING": "0",

    "_comment_telemetry": "Telemetry is OFF by default. To opt in, flip CLAUDE_CODE_ENABLE_TELEMETRY to '1' and fill the OTEL_* values. See docs/CUSTOMIZATION.md#telemetry.",
    "CLAUDE_CODE_ENABLE_TELEMETRY": "0",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "http/json",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "",
    "OTEL_RESOURCE_ATTRIBUTES": "",
    "OTEL_METRIC_EXPORT_INTERVAL": "10000",
    "OTEL_LOGS_EXPORT_INTERVAL": "10000"
  },

  "model": "claude-opus-4-6",

  "hooks": {
    "SessionStart": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash \"$HOME/.claude/hooks/global-memory-symlink.sh\"",
            "timeout": 5
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/shine-check-update.js\"",
            "timeout": 15
          }
        ]
      },
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/integration-sync.js\"",
            "timeout": 15
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Bash|Edit|Write|MultiEdit|Agent|Task",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/shine-context-monitor.js\"",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/shine-prompt-guard.js\"",
            "timeout": 5
          }
        ]
      },
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/shine-read-guard.js\"",
            "timeout": 5
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "node \"$HOME/.claude/hooks/shine-precompact.js\"",
            "timeout": 10
          }
        ]
      }
    ]
  },

  "statusLine": {
    "type": "command",
    "command": "node ~/.claude/statusline.js"
  },

  "enabledPlugins": {
    "code-simplifier@claude-plugins-official": true,
    "serena@claude-plugins-official": true,
    "ralph-loop@claude-plugins-official": true,
    "context7@claude-plugins-official": true,
    "typescript-lsp@claude-plugins-official": true,
    "supabase@claude-plugins-official": true,
    "pyright-lsp@claude-plugins-official": true,
    "pyright@claude-code-lsps": true,
    "basedpyright@claude-code-lsps": true,
    "superpowers@claude-plugins-official": true,
    "playwright@claude-plugins-official": true,
    "agent-sdk-dev@claude-plugins-official": true,
    "claude-code-setup@claude-plugins-official": true,
    "ui-ux-pro-max@ui-ux-pro-max-skill": true,
    "claude-mem@thedotmack": true,
    "arize-skills@Arize-ai-arize-skills": true
  },

  "extraKnownMarketplaces": {
    "ui-ux-pro-max-skill": {
      "source": {
        "source": "github",
        "repo": "nextlevelbuilder/ui-ux-pro-max-skill"
      }
    },
    "thedotmack": {
      "source": {
        "source": "github",
        "repo": "thedotmack/claude-mem"
      }
    },
    "Arize-ai-arize-skills": {
      "source": {
        "source": "github",
        "repo": "Arize-ai/arize-skills"
      }
    },
    "claude-code-lsps": {
      "source": {
        "source": "github",
        "repo": "Piebald-AI/claude-code-lsps"
      }
    }
  },

  "alwaysThinkingEnabled": true
}
